<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JS Paint Pro</title>
    <style>
        body { margin: 0; background: #333; font-family: sans-serif; display: flex; flex-direction: column; height: 100vh; }
        #toolbar { background: #222; padding: 10px; display: flex; gap: 15px; align-items: center; color: white; }
        canvas { background: white; cursor: crosshair; flex-grow: 1; }
        input[type="color"] { border: none; width: 40px; height: 40px; cursor: pointer; }
        button { padding: 8px 15px; cursor: pointer; background: #444; color: white; border: 1px solid #666; border-radius: 4px; }
        button:hover { background: #555; }
    </style>
</head>
<body>

    <div id="toolbar">
        <input type="color" id="colorPicker" value="#000000">
        <input type="range" id="lineWidth" min="1" max="50" value="5">
        <span id="sizeDisplay">5px</span>
        <button id="clearBtn">Clear Canvas</button>
        <button id="eraserBtn">Eraser</button>
    </div>

    <canvas id="paintCanvas"></canvas>

<script>
    const canvas = document.getElementById('paintCanvas');
    const ctx = canvas.getContext('2d');
    const colorPicker = document.getElementById('colorPicker');
    const lineWidth = document.getElementById('lineWidth');
    const sizeDisplay = document.getElementById('sizeDisplay');
    const clearBtn = document.getElementById('clearBtn');
    const eraserBtn = document.getElementById('eraserBtn');

    // Set canvas size
    function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight - document.getElementById('toolbar').offsetHeight;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    let painting = false;
    let isEraser = false;

    function startPosition(e) {
        painting = true;
        draw(e); // Allow single dots
    }

    function finishedPosition() {
        painting = false;
        ctx.beginPath(); // Resets the path so lines don't connect weirdly
    }

    function draw(e) {
        if (!painting) return;

        ctx.lineWidth = lineWidth.value;
        ctx.lineCap = 'round';
        ctx.strokeStyle = isEraser ? '#FFFFFF' : colorPicker.value;

        // Draw line to current mouse position
        ctx.lineTo(e.clientX, e.clientY - canvas.offsetTop);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(e.clientX, e.clientY - canvas.offsetTop);
    }

    // Listeners
    canvas.addEventListener('mousedown', startPosition);
    canvas.addEventListener('mouseup', finishedPosition);
    canvas.addEventListener('mousemove', draw);

    // Toolbar logic
    lineWidth.addEventListener('input', () => sizeDisplay.innerText = lineWidth.value + 'px');
    
    clearBtn.addEventListener('click', () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
    });

    eraserBtn.addEventListener('click', () => {
        isEraser = !isEraser;
        eraserBtn.style.background = isEraser ? '#cc0000' : '#444';
        eraserBtn.innerText = isEraser ? 'Brush' : 'Eraser';
    });
</script>
</body>
</html>
